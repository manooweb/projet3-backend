# Environment file example for knowing which key to use in the .env file.
# You can copy this file and rename it to .env and fill the values with your own credentials.

# Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=your_password
DB_NAME=your_database_name

# JWT configuration
JWT_SECRET=
JWT_EXPIRATION_SECONDS=
JWT_COOKIE_NAME=
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=Lax

# Mail configuration
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=
MAIL_SMTP_STARTTLS_ENABLE=
MAIL_FROM=
